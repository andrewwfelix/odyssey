---
const { activePage } = Astro.props;
---

<nav id="sidebar">
  <div id="sidebar-header">
    <button id="hamburger" onclick="toggleSidebar()" aria-label="Close menu">✕</button>
    <h1>THE COMPLETE GUIDE TO READING THE ILIAD</h1>
    <p>Everything before you open the book</p>
  </div>
  <div id="nav">
    <a class={`nav-item nolan-nav ${activePage === 'before-the-nolan-film' ? 'active' : ''}`} href="/before-the-nolan-film">Before the Nolan Film</a>
    <a class={`nav-item ${activePage === 'index' ? 'active' : ''}`} href="/">Introduction</a>
    <a class={`nav-item ${activePage === 'themes' ? 'active' : ''}`} href="/themes">Themes</a>
    <a class={`nav-item ${activePage === 'translations' ? 'active' : ''}`} href="/translations">Choosing a Translation</a>
    <a class={`nav-item ${activePage === 'how-to-read' ? 'active' : ''}`} href="/how-to-read">How to Read</a>
    <a class={`nav-item ${activePage === 'bronze-age-world' ? 'active' : ''}`} href="/bronze-age-world">Bronze Age World</a>
    <a class={`nav-item ${activePage === 'mythology' ? 'active' : ''}`} href="/mythology">Mythology</a>
    <a class={`nav-item ${activePage === 'ancient-historians' ? 'active' : ''}`} href="/ancient-historians">Ancient Historians</a>
    <a class={`nav-item ${activePage === 'modern-scholars' ? 'active' : ''}`} href="/modern-scholars">Modern Scholars</a>
    <a class={`nav-item ${activePage === 'after-the-iliad' ? 'active' : ''}`} href="/after-the-iliad">After the Iliad</a>
    <a class={`nav-item ${activePage === 'retellings' ? 'active' : ''}`} href="/retellings">Modern Retellings</a>
    <a class={`nav-item ${activePage === 'podcasts' ? 'active' : ''}`} href="/podcasts">Podcasts</a>
    <a class={`nav-item ${activePage === 'characters' ? 'active' : ''}`} href="/characters">Character Reference</a>
    <a class={`nav-item ${activePage === 'battle-and-geography' ? 'active' : ''}`} href="/battle-and-geography">Battle &amp; Geography</a>
    <a class={`nav-item ${activePage === 'synopsis' ? 'active' : ''}`} href="/synopsis">Book-by-Book Synopsis</a>
    <a class={`nav-item ${activePage === 'gods' ? 'active' : ''}`} href="/gods">The Gods</a>
    <a class={`nav-item ${activePage === 'glossary' ? 'active' : ''}`} href="/glossary">Key Terms Glossary</a>
    <a class={`nav-item ${activePage === 'bronze-age-collapse' ? 'active' : ''}`} href="/bronze-age-collapse">Bronze Age Collapse</a>
    <a class={`nav-item ${activePage === 'major-battles' ? 'active' : ''}`} href="/major-battles">Major Battles</a>
    <a class={`nav-item ${activePage === 'weapons-and-armor' ? 'active' : ''}`} href="/weapons-and-armor">Weapons &amp; Armor</a>
    <a class={`nav-item ${activePage === 'gift-guide' ? 'active' : ''}`} href="/gift-guide">Gift Guide</a>
    <a class="nav-item" href="https://readingtheodyssey.com" target="_blank" rel="noopener">Reading the Odyssey</a>
  </div>
</nav>

<div id="mobile-topbar">
  <button id="mobile-menu-btn" onclick="toggleSidebar()" aria-label="Open menu">☰</button>
  <span id="mobile-title">The Complete Guide to Reading the Iliad</span>
</div>

<div id="sidebar-overlay" onclick="toggleSidebar()"></div>

<script>
  function toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    sidebar.classList.toggle('open');
    overlay.classList.toggle('active');
  }
</script>