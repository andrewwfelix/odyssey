---
const { title, description, canonical } = Astro.props;
const nav = [
  { href: '/before-the-nolan-film', label: 'Before the Nolan Film', nolan: true },
  { href: '/', label: 'Introduction' },
  { href: '/themes', label: 'Themes' },
  { href: '/translations', label: 'Choosing a Translation' },
  { href: '/how-to-read', label: 'How to Read' },
  { href: '/world', label: 'The World of Odysseus' },
  { href: '/mythology', label: 'Mythology' },
  { href: '/ancient-historians', label: 'Ancient Historians' },
  { href: '/modern-scholars', label: 'Modern Scholars' },
  { href: '/after-the-odyssey', label: 'After the Odyssey' },
  { href: '/retellings', label: 'Modern Retellings' },
  { href: '/podcasts', label: 'Podcasts' },
  { href: '/characters', label: 'Character Reference' },
  { href: '/journey', label: 'The Journey Map' },
  { href: '/synopsis', label: 'Book-by-Book Synopsis' },
  { href: '/gods', label: 'The Gods' },
  { href: '/glossary', label: 'Key Terms Glossary' },
  { href: '/ref-themes', label: 'Themes & Motifs' },
  { href: '/protagonists', label: 'Two Protagonists' },
  { href: '/episodes', label: 'Key Episodes' },
  { href: '/gift-guide', label: 'Gift Guide' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://readingtheodyssey.com/images/landing_image.jpg" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://readingtheodyssey.com/images/landing_image.jpg" />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Upright:ital,wght@0,400;0,600;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-EWPG59C7VV"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EWPG59C7VV');
  </script>
</head>
<body>
  <nav id="sidebar">
    <div id="sidebar-header">
      <button id="hamburger" aria-label="Close menu">✕</button>
      <h1>THE COMPLETE GUIDE TO READING THE ODYSSEY</h1>
      <p>Everything before you open the book</p>
    </div>
    <div id="nav">
      {nav.map(item => (
        <a
          class={`nav-item${item.nolan ? ' nolan-nav' : ''}`}
          href={item.href}
        >{item.label}</a>
      ))}
      <a class="nav-item" href="https://readingtheiliad.com" target="_blank" rel="noopener">Reading the Iliad</a>
    </div>
  </nav>

  <div id="mobile-topbar">
    <button id="mobile-menu-btn" aria-label="Open menu">☰</button>
    <span id="mobile-title">The Complete Guide to Reading the Odyssey</span>
  </div>

  <div id="sidebar-overlay"></div>

  <main id="main">
    <div id="content-scroll">
      <slot />
    </div>
  </main>

  <script>
    // Auto-highlight active nav item based on current URL
    const currentPath = window.location.pathname;
    document.querySelectorAll('#nav a').forEach(link => {
      const linkPath = new URL(link.href).pathname;
      if (linkPath === currentPath || (currentPath === '/' && linkPath === '/')) {
        link.classList.add('active');
      }
    });

    function toggleSidebar() {
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      sidebar.classList.toggle('open');
      overlay.classList.toggle('active');
    }
    document.getElementById('hamburger').addEventListener('click', toggleSidebar);
    document.getElementById('mobile-menu-btn').addEventListener('click', toggleSidebar);
    document.getElementById('sidebar-overlay').addEventListener('click', toggleSidebar);
    document.querySelectorAll('#nav a').forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 768) toggleSidebar();
      });
    });
  </script>
</body>
</html>
