      <a class="nav-item" href="/gods">The Gods</a>
      <a class="nav-item" href="/glossary">Key Terms Glossary</a>
      <a class="nav-item" href="/ref-themes">Themes &amp; Motifs</a>
      <a class="nav-item" href="/protagonists">Two Protagonists</a>
