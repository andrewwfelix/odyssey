const canonical = `https://readingtheodyssey.com/after-the-odyssey`;
---

<Layout title={title} description={description} canonical={canonical}>
  <nav id="sidebar">
    <div id="sidebar-header">
      <button id="hamburger" onclick="toggleSidebar()" aria-label="Close menu">✕</button>
      <h1>THE COMPLETE GUIDE TO READING THE ODYSSEY</h1>
