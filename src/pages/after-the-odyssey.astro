    </div>
    <div id="nav">
      <a class="nav-item nolan-nav" href="/before-the-nolan-film">Before the Nolan Film</a>
      <a class="nav-item" href="/">Introduction</a>
      <a class="nav-item" href="/themes">Themes</a>
      <a class="nav-item" href="/translations">Choosing a Translation</a>
